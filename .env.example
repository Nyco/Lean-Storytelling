# Database
DATABASE_URL=postgresql://ls_user:ls_password@db:5432/lean_storytelling
POSTGRES_DB=lean_storytelling
POSTGRES_USER=ls_user
POSTGRES_PASSWORD=change_me_local

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_minimum_32_characters

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=noreply@yourdomain.com

# App
FRONTEND_URL=http://localhost:3000
# FRONTEND_DIR=/app/frontend  # set automatically by docker-compose
